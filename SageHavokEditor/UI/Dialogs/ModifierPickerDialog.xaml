<Window x:Class="SageHavokEditor.UI.Dialogs.ModifierPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Modifier" Height="480" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Text="Choose a modifier type to create:"/>

        <TextBox x:Name="FilterBox" Grid.Row="1" Padding="5" Margin="0,0,0,8"
                 TextChanged="FilterBox_TextChanged"
                 ToolTip="Type to filter the list"/>

        <ListBox x:Name="List" Grid.Row="2"
                 MouseDoubleClick="List_MouseDoubleClick"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Create" Width="80" Margin="0,0,8,0"
                    Click="BtnOk_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
