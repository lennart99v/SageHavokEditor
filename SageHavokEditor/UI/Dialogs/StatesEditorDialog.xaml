<Window x:Class="SageHavokEditor.UI.Dialogs.StatesEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit States" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkBrush}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left: current states -->
        <TextBlock Grid.Column="0" Text="Current States" 
                   FontWeight="Bold" Margin="0,0,0,6"/>
        <ListBox Grid.Column="0" Grid.Row="1" x:Name="CurrentList"
                 ItemsSource="{Binding CurrentStates}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Id}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="10" Margin="0,0,6,0" 
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Middle buttons -->
        <StackPanel Grid.Column="1" Grid.Row="1" 
                    VerticalAlignment="Center" Margin="8,0">
            <Button Content="◀ Add" Click="BtnAdd_Click" 
                    Margin="0,0,0,8"/>
            <Button Content="Remove ▶" Click="BtnRemove_Click"/>
        </StackPanel>

        <!-- Right: available states with filter -->
        <TextBlock Grid.Column="2" Text="Available States" 
                   FontWeight="Bold" Margin="0,0,0,6"/>
        <DockPanel Grid.Column="2" Grid.Row="1">
            <TextBox DockPanel.Dock="Top" x:Name="TxtFilter" 
                     Margin="0,0,0,4"
                     TextChanged="TxtFilter_TextChanged"/>
            <ListBox x:Name="AvailableList" 
                     ItemsSource="{Binding AvailableStates}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Id}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10" Margin="0,0,6,0" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- OK/Cancel -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" 
                    Click="BtnOK_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" 
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>