<Window x:Class="SkyrimHavokEditor.UI.Dialogs.CompareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SkyrimHavokEditor"
        Title="Compare Behavior Files"
        Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File pickers -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File A -->
            <Border Grid.Column="0" Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="File A (current)" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="FileALabel" Text="(loaded file)"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Column="1" Text="⇄" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <!-- File B -->
            <Border Grid.Column="2" Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="File B" FontWeight="Bold"
                               Foreground="{DynamicResource AccentGreenBrush}" Margin="0,0,0,4"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FileBLabel" Text="No file selected"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Browse..." Padding="8,3"
                                Margin="8,0,0,0" Click="BtnBrowseB_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Filter options -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <CheckBox x:Name="ChkVariables" Content="Variables" IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="ChkEvents"    Content="Events"    IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="ChkClips"     Content="Clips"     IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="ChkObjects"   Content="Objects"   IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,20,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="ChkHideSame"  Content="Hide identical" IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <TextBlock x:Name="SummaryText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center"/>
        </WrapPanel>

        <!-- Column headers -->
        <Grid Grid.Row="2" Margin="0,0,0,4"
              Background="{DynamicResource BgPanelBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Type"    FontWeight="Bold" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,4"/>
            <TextBlock Grid.Column="1" Text="Diff"    FontWeight="Bold" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,4"/>
            <TextBlock Grid.Column="2" Text="Name/ID" FontWeight="Bold" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,4"/>
            <TextBlock Grid.Column="3" Text="File A"  FontWeight="Bold" FontSize="11"
                       Foreground="{DynamicResource AccentBlueBrush}"   Margin="4,4"/>
            <TextBlock Grid.Column="4" Text="File B"  FontWeight="Bold" FontSize="11"
                       Foreground="{DynamicResource AccentGreenBrush}"  Margin="4,4"/>
        </Grid>

        <!-- Results -->
        <ListBox x:Name="ResultsList" Grid.Row="3"
                 Background="{DynamicResource BgMidBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 SelectionChanged="ResultsList_SelectionChanged"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Category -->
                        <TextBlock Grid.Column="0" Text="{Binding Category}"
                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <!-- Diff type badge -->
                        <Border Grid.Column="1" CornerRadius="3" Padding="5,2"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource BadgeGrayBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiffType}" Value="Added">
                                            <Setter Property="Background" Value="{DynamicResource BadgeGreenBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DiffType}" Value="Removed">
                                            <Setter Property="Background" Value="{DynamicResource BadgePurpleBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DiffType}" Value="Modified">
                                            <Setter Property="Background" Value="{DynamicResource BadgeYellowBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding DiffType}" FontSize="10" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiffType}" Value="Added">
                                                <Setter Property="Foreground" Value="{DynamicResource BadgeGreenTextBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiffType}" Value="Removed">
                                                <Setter Property="Foreground" Value="{DynamicResource BadgePurpleTextBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiffType}" Value="Modified">
                                                <Setter Property="Foreground" Value="{DynamicResource BadgeYellowTextBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Name -->
                        <TextBlock Grid.Column="2" Text="{Binding Name}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" Margin="4,0"/>

                        <!-- Value A -->
                        <TextBlock Grid.Column="3" Text="{Binding ValueA}"
                                   FontSize="11" Foreground="{DynamicResource AccentBlueBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" Margin="4,0"/>

                        <!-- Value B -->
                        <TextBlock Grid.Column="4" Text="{Binding ValueB}"
                                   FontSize="11" Foreground="{DynamicResource AccentGreenBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" Margin="4,0"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Export Diff" Click="BtnExportDiff_Click"
                    Padding="12,5" Margin="0,0,5,0"/>
            <Button Content="Close" Click="BtnClose_Click" Padding="12,5"/>
        </StackPanel>
    </Grid>
</Window>
