<UserControl x:Class="SkyrimHavokEditor.UI.Dialogs.DebugPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Expander header style — flush, no chrome -->
        <Style x:Key="GroupExpanderStyle" TargetType="Expander">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          IsChecked="{Binding IsExpanded,
                                          Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="6,3"
                                          HorizontalContentAlignment="Stretch"
                                          HorizontalAlignment="Stretch"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="0,0,0,1"
                                                BorderBrush="#22334455"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="Content" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Content" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: ACTIVE STATES label -->
            <RowDefinition Height="80"/>
            <!-- Row 2: Active States -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: TRANSITION HISTORY label -->
            <RowDefinition Height="110"/>
            <!-- Row 4: Transition History -->
            <RowDefinition Height="Auto"/>
            <!-- Row 5: VARIABLES label -->
            <RowDefinition Height="*"/>
            <!-- Row 6: Variables ScrollViewer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{Binding HeaderBg}" Padding="8,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse Width="8" Height="8" Fill="{Binding DotFill}"
                             Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActorIcon}"
                               FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActorLabel}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#D4D4D4" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="{Binding PauseContent}" ToolTip="Pause/Resume"
                            Click="BtnPause_Click" Padding="4,2" Margin="0,0,2,0" FontSize="10"/>
                    <Button Content="{Binding RecordContent}" Foreground="{Binding RecordFg}"
                            ToolTip="Record" Click="BtnRecord_Click"
                            Padding="4,2" Margin="0,0,2,0" FontSize="10"/>
                    <Button Content="💾" ToolTip="Export recording"
                            Click="BtnExport_Click" Padding="4,2" FontSize="10"/>
                    <Button Content="🎯" Opacity="{Binding PanToOpacity}"
                            ToolTip="Pan to active" Click="BtnPanToActive_Click"
                            Padding="4,2" Margin="2,0,0,0" FontSize="10"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Active States label -->
        <TextBlock Grid.Row="1" Text="ACTIVE STATES" FontSize="9" FontWeight="Bold"
                   Foreground="#4FC3F7" Margin="8,5,8,2"/>

        <!-- Active States -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Margin="6,0,6,4" Padding="0,0,12,0">
            <ItemsControl x:Name="ActiveStatesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1" Padding="5,3"
                                Background="#0D1A2A" CornerRadius="3">
                            <StackPanel>
                                <TextBlock Text="{Binding SMName}" FontSize="8"
                                           Foreground="#4FC3F7" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding StateName}" FontSize="10"
                                           Foreground="#00FF80" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Transition History label -->
        <TextBlock Grid.Row="3" Text="TRANSITION HISTORY" FontSize="9" FontWeight="Bold"
                   Foreground="#9D9D9D" Margin="8,4,8,2"/>

        <!-- Transition History -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                      Margin="6,0,6,4" Padding="0,0,12,0">
            <ItemsControl x:Name="HistoryList" AlternationCount="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RowBg" Background="Transparent">
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Time}" FontSize="8"
                                           Foreground="#555570" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" FontSize="9"
                                           Foreground="#8888AA"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Value="1"
                                Binding="{Binding Path=(ItemsControl.AlternationIndex),
                                          RelativeSource={RelativeSource AncestorType=ContentPresenter}}">
                                <Setter TargetName="RowBg" Property="Background" Value="#0A0A12"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Variables label -->
        <TextBlock Grid.Row="5" Text="VARIABLES" FontSize="9" FontWeight="Bold"
                   Foreground="#9D9D9D" Margin="8,4,8,2"/>

        <!-- Grouped variables -->
        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto"
                      Margin="4,0,4,4" Padding="0,0,12,0">
            <StackPanel>

                <!-- ── Actor group ─────────────────────────────────── -->
                <Expander Style="{StaticResource GroupExpanderStyle}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActorIcon}"
                                       FontSize="11" Margin="0,0,5,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActorLabel}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <ItemsControl x:Name="LiveVarsList" AlternationCount="2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBg" Background="Transparent">
                                    <Grid Margin="6,1,4,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="10"
                                                   Foreground="{Binding NameBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayValue}"
                                                   FontSize="10"
                                                   Foreground="{Binding ValueBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                        <Setter TargetName="RowBg" Property="Background" Value="#0A0E14"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!-- ── Mount group — only when mounted ────────────── -->
                <Expander Style="{StaticResource GroupExpanderStyle}"
                          Visibility="{Binding DragonVis}"
                          Margin="0,4,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐉" FontSize="11"
                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DragonLabel}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding DragonAccent}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <ItemsControl x:Name="DragonVarsList" AlternationCount="2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBg" Background="Transparent">
                                    <Grid Margin="6,1,4,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="10"
                                                   Foreground="#7A6A9A"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value, StringFormat={}{0:F2}}"
                                                   FontSize="10" Foreground="#C586C0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                        <Setter TargetName="RowBg" Property="Background" Value="#0A0E14"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>