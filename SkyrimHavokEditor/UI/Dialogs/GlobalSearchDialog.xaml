<Window x:Class="SkyrimHavokEditor.UI.Dialogs.GlobalSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global Search &amp; Replace"
        Height="660" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        Opacity="1.0"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">

    <Border Background="#EF1E1E1E"
            BorderBrush="#FF3C3C3F"
            BorderThickness="1"
            CornerRadius="6">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown"
                  Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔭  Global Search &amp; Replace"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Padding="8,3"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Row 1: Search bar -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Padding="8,6" FontSize="13"
                         TextChanged="TxtSearch_TextChanged"
                         KeyDown="TxtSearch_KeyDown"/>
                <TextBlock Grid.Column="0"
                           Text="🔍  Search everything...  (event:  clip:  state:  var:  obj:  prefixes supported)"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           IsHitTestVisible="False"
                           Visibility="{Binding PlaceholderVisibility}"/>
                <TextBlock x:Name="ResultCount" Grid.Column="1"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>

            <!-- Row 2: Replace bar (collapsed by default) -->
            <Grid x:Name="ReplaceRow" Grid.Row="2" Margin="0,0,0,6" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtReplace" Padding="8,6" FontSize="13"/>
                <Button Grid.Column="1" Content="Replace Selected" Margin="6,0,0,0"
                        Padding="10,5" Click="BtnReplaceSelected_Click"/>
                <Button Grid.Column="2" Content="Replace All" Margin="4,0,0,0"
                        Padding="10,5" Click="BtnReplaceAll_Click"/>
            </Grid>

            <!-- Row 3: Filter chips + options -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filter: " Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ToggleButton x:Name="FilterAll"       Content="All"         IsChecked="True"
                                  Margin="0,0,3,0" Padding="8,3" FontSize="11" Click="Filter_Click" Tag="all"/>
                    <ToggleButton x:Name="FilterEvents"    Content="⚡ Events"
                                  Margin="0,0,3,0" Padding="8,3" FontSize="11" Click="Filter_Click" Tag="event"/>
                    <ToggleButton x:Name="FilterClips"     Content="▶ Clips"
                                  Margin="0,0,3,0" Padding="8,3" FontSize="11" Click="Filter_Click" Tag="clip"/>
                    <ToggleButton x:Name="FilterStates"    Content="🔳 States"
                                  Margin="0,0,3,0" Padding="8,3" FontSize="11" Click="Filter_Click" Tag="state"/>
                    <ToggleButton x:Name="FilterVariables" Content="⚙ Variables"
                                  Margin="0,0,3,0" Padding="8,3" FontSize="11" Click="Filter_Click" Tag="var"/>
                    <ToggleButton x:Name="FilterObjects"   Content="# Objects"
                                  Margin="0,0,3,0" Padding="8,3" FontSize="11" Click="Filter_Click" Tag="obj"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="ChkCaseSensitive" Content="Case" VerticalAlignment="Center"
                              Margin="0,0,8,0" FontSize="11"/>
                    <CheckBox x:Name="ChkRegex" Content="Regex" VerticalAlignment="Center"
                              Margin="0,0,8,0" FontSize="11"/>
                    <ToggleButton x:Name="BtnToggleReplace" Content="± Replace"
                                  Padding="8,3" FontSize="11" Click="BtnToggleReplace_Click"/>
                </StackPanel>
            </Grid>

            <!-- Row 4: Results list -->
            <ListView x:Name="ResultsList" Grid.Row="4"
                      SelectionChanged="ResultsList_SelectionChanged"
                      MouseDoubleClick="ResultsList_DoubleClick"
                      BorderBrush="{StaticResource BorderBrush}"
                      Background="{StaticResource BgMidBrush}"
                      SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="75">
                            <GridViewColumn.Header>
                                <TextBlock Text="Type" FontWeight="SemiBold"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="4,1"
                                            Background="{Binding CategoryBrush}">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CategoryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="190">
                            <GridViewColumn.Header>
                                <TextBlock Text="Name" FontWeight="SemiBold"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="100">
                            <GridViewColumn.Header>
                                <TextBlock Text="ID" FontWeight="SemiBold"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="340">
                            <GridViewColumn.Header>
                                <TextBlock Text="Details / Value" FontWeight="SemiBold"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Details}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Row 5: Footer -->
            <Grid Grid.Row="5" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HintText"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center"
                           Text="↵ Jump   •   Double-click to navigate   •   ± Replace to edit values"/>
                <Button Grid.Column="1" Content="Close" Click="BtnClose_Click" Padding="12,5"/>
            </Grid>
        </Grid>
    </Border>
</Window>
