<Window x:Class="SkyrimHavokEditor.UI.Dialogs.GlobalSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global Search &amp; Replace"
        Height="660" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        Opacity="1.0"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <!-- ToggleButton style scoped to this dialog so it doesn't need to be in the theme -->
        <Style x:Key="FilterChipStyle" TargetType="ToggleButton">
            <Setter Property="Background"       Value="{DynamicResource BgMidBrush}"/>
            <Setter Property="Foreground"       Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,4"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgSelectedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔭  Global Search &amp; Replace"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Padding="8,3"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Row 1: Search bar -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Padding="8,6" FontSize="13"
                         TextChanged="TxtSearch_TextChanged"
                         KeyDown="TxtSearch_KeyDown"/>
                <TextBlock Grid.Column="0"
                           Text="🔍  Search everything...  (event:  clip:  state:  var:  obj:  prefixes supported)"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           IsHitTestVisible="False"
                           Visibility="{Binding PlaceholderVisibility}"/>
                <TextBlock x:Name="ResultCount" Grid.Column="1"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>

            <!-- Row 2: Replace bar (collapsed by default) -->
            <Grid x:Name="ReplaceRow" Grid.Row="2" Margin="0,0,0,6" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtReplace" Padding="8,6" FontSize="13"/>
                <Button Grid.Column="1" Content="Replace Selected" Margin="6,0,0,0"
                        Padding="10,5" Click="BtnReplaceSelected_Click"/>
                <Button Grid.Column="2" Content="Replace All" Margin="4,0,0,0"
                        Padding="10,5" Click="BtnReplaceAll_Click"/>
            </Grid>

            <!-- Row 3: Filter chips + options -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filter: " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ToggleButton x:Name="FilterAll"       Content="All"         IsChecked="True"
                                  Style="{StaticResource FilterChipStyle}"
                                  Margin="0,0,3,0" Click="Filter_Click" Tag="all"/>
                    <ToggleButton x:Name="FilterEvents"    Content="⚡ Events"
                                  Style="{StaticResource FilterChipStyle}"
                                  Margin="0,0,3,0" Click="Filter_Click" Tag="event"/>
                    <ToggleButton x:Name="FilterClips"     Content="▶ Clips"
                                  Style="{StaticResource FilterChipStyle}"
                                  Margin="0,0,3,0" Click="Filter_Click" Tag="clip"/>
                    <ToggleButton x:Name="FilterStates"    Content="🔳 States"
                                  Style="{StaticResource FilterChipStyle}"
                                  Margin="0,0,3,0" Click="Filter_Click" Tag="state"/>
                    <ToggleButton x:Name="FilterVariables" Content="⚙ Variables"
                                  Style="{StaticResource FilterChipStyle}"
                                  Margin="0,0,3,0" Click="Filter_Click" Tag="var"/>
                    <ToggleButton x:Name="FilterObjects"   Content="# Objects"
                                  Style="{StaticResource FilterChipStyle}"
                                  Margin="0,0,3,0" Click="Filter_Click" Tag="obj"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="ChkCaseSensitive" Content="Case"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                    <CheckBox x:Name="ChkRegex" Content="Regex"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                    <ToggleButton x:Name="BtnToggleReplace" Content="± Replace"
                                  Style="{StaticResource FilterChipStyle}"
                                  Click="BtnToggleReplace_Click"/>
                </StackPanel>
            </Grid>

            <!-- Row 4: Results list -->
            <ListView x:Name="ResultsList" Grid.Row="4"
                      SelectionChanged="ResultsList_SelectionChanged"
                      MouseDoubleClick="ResultsList_DoubleClick"
                      BorderBrush="{DynamicResource BorderBrush}"
                      Background="{DynamicResource BgMidBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      SelectionMode="Extended">
                <ListView.Resources>
                    <!-- Override ListViewItem so selected rows are readable in both themes -->
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="ItemBd"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0" Padding="{TemplateBinding Padding}">
                                        <GridViewRowPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background"
                                                    Value="{DynamicResource BgHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background"
                                                    Value="{DynamicResource BgSelectedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource BgPanelBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Width="75" Header="Type">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="4,1"
                                            Background="{Binding CategoryBrush}">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CategoryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="190" Header="Name">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="100" Header="ID">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="340" Header="Details / Value">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Details}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Row 5: Footer -->
            <Grid Grid.Row="5" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HintText"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center"
                           Text="↵ Jump   •   Double-click to navigate   •   ± Replace to edit values"/>
                <Button Grid.Column="1" Content="Close" Click="BtnClose_Click" Padding="12,5"/>
            </Grid>
        </Grid>
    </Border>
</Window>
