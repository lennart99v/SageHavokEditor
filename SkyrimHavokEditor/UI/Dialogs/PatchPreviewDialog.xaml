<Window x:Class="SkyrimHavokEditor.UI.Dialogs.PatchPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Behavior Patch"
        Height="620" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="📦 Generate Behavior Patch"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Review the changes below. Uncheck any operations you want to exclude."
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Metadata -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Author" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtAuthor" Padding="6,4"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Description" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtDescription" Padding="6,4"/>
            </StackPanel>
        </Grid>

        <!-- Toolbar + summary -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Select All" Padding="8,4"
            Margin="0,0,5,0" Click="BtnSelectAll_Click"/>
            <Button Grid.Column="1" Content="Select None" Padding="8,4"
            Margin="0,0,12,0" Click="BtnSelectNone_Click"/>
            <Button Grid.Column="2" Content="⬡ Export Nemesis" Click="BtnExportNemesis_Click"
            Padding="10,4" Margin="0,0,6,0"/>
            <Button Grid.Column="3" Content="⬡ Export Pandora" Click="BtnExportPandora_Click"
            Padding="10,4" Margin="0,0,6,0"/>
            <TextBlock x:Name="SummaryText" Grid.Column="4"
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="11" VerticalAlignment="Center"/>
        </Grid>

        <!-- Operations list -->
        <ListBox Grid.Row="3" ItemsSource="{Binding Ops}"
                 Background="{StaticResource BgMidBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>

                        <Border Grid.Column="1" CornerRadius="3" Padding="5,2"
                                Margin="0,0,8,0" VerticalAlignment="Center"
                                Background="{Binding TypeColor}">
                            <TextBlock Text="{Binding TypeLabel}"
                                       FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#89D185"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TypeLabel}" Value="DEL">
                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeLabel}" Value="MOD">
                                                <Setter Property="Foreground" Value="Orange"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeLabel}" Value="APD">
                                                <Setter Property="Foreground" Value="Orange"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeLabel}" Value="EVT">
                                                <Setter Property="Foreground" Value="#C586C0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeLabel}" Value="VAR">
                                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Note}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Note}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsIncluded}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Padding="12,6"
                    Margin="0,0,6,0" Click="BtnCancel_Click"/>
            <Button Content="💾 Save Patch" Padding="14,6"
                    Click="BtnSave_Click"
                    Background="{StaticResource BgSelectedBrush}"/>
        </StackPanel>
    </Grid>
</Window>
