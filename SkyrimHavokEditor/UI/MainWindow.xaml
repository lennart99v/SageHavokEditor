<Window x:Class="SkyrimHavokEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkyrimHavokEditor"
        xmlns:converters="clr-namespace:SkyrimHavokEditor.UI.Converters"
        xmlns:ui="clr-namespace:SkyrimHavokEditor.UI"
        xmlns:dialogs="clr-namespace:SkyrimHavokEditor.UI.Dialogs"
        xmlns:models="clr-namespace:SkyrimHavokEditor.Models"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Skyrim Havok Behavior Editor" Height="700" Width="1200"
        Background="{DynamicResource BgDarkBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <converters:StringToVisibilityConverter  x:Key="StringToVisibilityConverter"/>
        <converters:ReferenceCheckConverter      x:Key="ReferenceCheckConverter"/>
        <BooleanToVisibilityConverter            x:Key="BooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter    x:Key="NullToVisibilityConverter"/>

        <HierarchicalDataTemplate DataType="{x:Type models:BehaviorNodeData}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="Icon" Margin="0,0,5,0" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Root">
                    <Setter TargetName="Icon" Property="Text" Value="🕸️"/>
                    <Setter TargetName="Icon" Property="Foreground" Value="DimGray"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="StateMachine">
                    <Setter TargetName="Icon" Property="Text" Value="⚙️"/>
                    <Setter TargetName="Icon" Property="Foreground" Value="Goldenrod"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="State">
                    <Setter TargetName="Icon" Property="Text" Value="🔳"/>
                    <Setter TargetName="Icon" Property="Foreground" Value="DodgerBlue"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Generator">
                    <Setter TargetName="Icon" Property="Text" Value="▶"/>
                    <Setter TargetName="Icon" Property="Foreground" Value="{x:Static Brushes.LimeGreen}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Transition">
                    <Setter TargetName="Icon" Property="Text" Value="➔"/>
                    <Setter TargetName="Icon" Property="Foreground" Value="{x:Static Brushes.MediumPurple}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Modifier">
                    <Setter TargetName="Icon" Property="Text" Value="🔧"/>
                    <Setter TargetName="Icon" Property="Foreground" Value="{x:Static Brushes.OrangeRed}"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid Background="{DynamicResource BgDarkBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <!-- title bar -->
                <RowDefinition Height="*"/>
                <!-- main content -->
                <RowDefinition Height="Auto"/>
                <!-- status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════
                 TITLE BAR
            ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="{DynamicResource BgPanelBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Skyrim Havok Editor"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="12,0,20,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,3">
                    <Button x:Name="BtnLoad" Content="Load" Click="BtnLoad_Click"
                            ToolTip="Open file (Ctrl+O)" Margin="0,0,2,0"/>
                    <Button Content="▾" Width="16" Padding="0" Margin="0,0,8,0"
                            ToolTip="Recent files" Click="BtnRecentFiles_Click"/>
                    <Button Content="Save" Click="BtnSave_Click"
                            ToolTip="Save file (Ctrl+S)" Margin="0,0,5,0"/>
                    <Button x:Name="BtnUndo" Content="↩" Click="BtnUndo_Click"
                            IsEnabled="False" ToolTip="Undo (Ctrl+Z)" Margin="0,0,2,0"/>
                    <Button x:Name="BtnRedo" Content="↪" Click="BtnRedo_Click"
                            IsEnabled="False" ToolTip="Redo (Ctrl+Y)" Margin="0,0,8,0"/>
                    <Button Content="📤 Export" Click="BtnExport_Click"
                            ToolTip="Export CSV (Ctrl+E)" Margin="0,0,5,0"/>
                    <Button Content="🔎 Validate" Click="BtnValidate_Click"
                            Margin="0,0,5,0"/>
                    <Button Content="🔭 Search" Click="BtnGlobalSearch_Click"
                            ToolTip="Global search (Ctrl+G)" Margin="0,0,5,0"/>
                    <Button Content="⇄ Compare" Click="BtnCompare_Click"
                            Margin="0,0,5,0"/>
                    <Button x:Name="BtnDebugger"
        Content="🎮 Live Debug"
        Click="BtnDebugger_Click"
        Padding="8,4" Margin="4,0"/>
                    <Button Content="📦 Patch" Click="BtnGeneratePatch_Click"
                            Margin="0,0,2,0"/>
                    <Button Content="🔧 Apply Patch" Click="BtnApplyPatch_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnTheme" Content="☀ Light" Click="BtnTheme_Click"/>
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="─" Width="46" Height="38" Padding="0"
                            Click="BtnMinimize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="FontSize"     Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnMaximize" Content="□" Width="46" Height="38" Padding="0"
                            Click="BtnMaximize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="FontSize"     Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Width="46" Height="38" Padding="0"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="FontSize"     Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#C42B1C"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 MAIN CONTENT — three columns
            ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="120"/>
                    <!-- tree -->
                    <ColumnDefinition Width="5"/>
                    <!-- splitter -->
                    <ColumnDefinition Width="*"   MinWidth="300"/>
                    <!-- tabs -->
                    <ColumnDefinition Width="5"/>
                    <!-- splitter -->
                    <ColumnDefinition Width="280" MinWidth="180"/>
                    <!-- object data -->
                </Grid.ColumnDefinitions>

                <!-- ── COL 0: Tree ──────────────────────────────────────── -->
                <DockPanel Grid.Column="0"
                           Background="{DynamicResource BgMidBrush}">

                    <!-- Tree search -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="6,5">
                        <TextBox x:Name="TxtSearch"
                                 Padding="3"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="🔍 Filter behaviors…"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Margin="5,3"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <TreeView x:Name="ObjectTree"
                              SelectedItemChanged="ObjectTree_SelectedItemChanged"
                              Background="Transparent"
                              BorderThickness="0">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border x:Name="ItemBorder" Background="Transparent" Padding="2,1">
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="Left"/>
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background"
                                                            Value="{DynamicResource BgHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background"
                                                            Value="{DynamicResource BgSelectedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>

                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"
                              ResizeDirection="Columns" Cursor="SizeWE"/>

                <!-- ── COL 2: Tabs (Graph first, no Object Data tab) ─────── -->
                <TabControl x:Name="MainTabControl" Grid.Column="2"
                            Background="{DynamicResource BgDarkBrush}">

                    <!-- ─── Graph ────────────────────────────────────────── -->
                    <TabItem Header="⚙ Graph">
                        <ui:StateMachineGraphView x:Name="GraphView"/>
                    </TabItem>

                    <!-- ─── Variables ────────────────────────────────────── -->
                    <!-- ─── Variables ────────────────────────────────────── -->
                    <TabItem Header="Variables">
                        <DockPanel Margin="0,5,0,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,6">
                                <Button Content="+ Add Variable" Click="BtnAddVariable_Click"
                    Padding="8,4" Margin="0,0,6,0"/>
                                <Button x:Name="BtnDeleteVariable" Content="− Delete Variable"
                    Click="BtnDeleteVariable_Click"
                    Padding="8,4" IsEnabled="False"/>
                            </StackPanel>
                            <TextBox DockPanel.Dock="Top" Margin="4,0,4,5" Padding="3"
                 x:Name="VarSearchBox"
                 Text="{Binding VariableFilter, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Filter variables…"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="5,3"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Usage panel -->
                            <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" MaxHeight="180">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Margin="5,5,0,3" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Select a variable to see usages"
                           Visibility="{Binding SelectedVariable, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    <TextBlock DockPanel.Dock="Top" Margin="5,5,0,3" FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Visibility="{Binding SelectedVariable, Converter={StaticResource NullToVisibilityConverter}}">
                    <Run Text="Usages of: "/>
                    <Run Text="{Binding SelectedVariable.Name}" FontWeight="Bold"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
                                    </TextBlock>
                                    <ListBox ItemsSource="{Binding UsageView}" FontSize="11">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding UsedBy}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                        <Border CornerRadius="3" Padding="4,1" VerticalAlignment="Center"
                                            Background="{DynamicResource BadgeBlueBrush}">
                                                            <TextBlock Text="{Binding BindingType}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,1,0,0">
                                                        <TextBlock Text="{Binding ClassName}" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                                        <TextBlock Text="→" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Property}" FontSize="10"
                                               Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <ListBox x:Name="VariablesList" ItemsSource="{Binding VariablesView}"
                 SelectionChanged="VariablesList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Index}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Padding="4,1" FontSize="10" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Name}"/>

                                            <Border Grid.Column="2" CornerRadius="3" Padding="4,1"
                                Margin="4,0,4,0" VerticalAlignment="Center"
                                Background="{Binding TypeColor}">
                                                <TextBlock Text="{Binding TypeShort}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#CCCCCC"
                                       HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- TextBox for non-bool -->
                                            <TextBox Grid.Column="3"
                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 Padding="4,2" FontSize="11"
                                 VerticalAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VariableType}" Value="VARIABLE_TYPE_BOOL">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <!-- ComboBox for bool — properties set directly to force dark theme -->
                                            <ComboBox Grid.Column="3"
                                  SelectedItem="{Binding BoolDisplayValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  FontSize="11" Padding="4,2"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource BgInputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                                                <ComboBox.Items>
                                                    <system:String>true</system:String>
                                                    <system:String>false</system:String>
                                                </ComboBox.Items>
                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VariableType}" Value="VARIABLE_TYPE_BOOL">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ─── Clips ─────────────────────────────────────────── -->
                    <TabItem Header="Clips">
                        <DockPanel Margin="0,5,0,0">
                            <TextBox DockPanel.Dock="Top" Margin="5,0,5,5" Padding="3"
                                     x:Name="ClipSearchBox"
                                     Text="{Binding ClipFilter, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Filter clips…"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           Margin="5,3"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Trigger panel -->
                            <Border DockPanel.Dock="Bottom"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0" MaxHeight="180">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Margin="5,5,0,3" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Select a clip to see its triggers"
                                               Visibility="{Binding SelectedClip, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    <TextBlock DockPanel.Dock="Top" Margin="5,5,0,3" FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Visibility="{Binding SelectedClip, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Run Text="Triggers: "/>
                                        <Run Text="{Binding SelectedClip.Name}" FontWeight="Bold"
                                             Foreground="{DynamicResource AccentGreenBrush}"/>
                                    </TextBlock>
                                    <ListBox ItemsSource="{Binding TriggerList}" FontSize="11">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="⚡ " Foreground="{DynamicResource BadgePurpleTextBrush}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding EventName}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                    <TextBlock Text="t=" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                                    <TextBlock Text="{Binding LocalTime}" FontSize="10" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <ListBox x:Name="ClipsList" ItemsSource="{Binding ClipsView}"
                                     SelectionChanged="ClipsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▶ " Foreground="{DynamicResource AccentGreenBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                    Background="{DynamicResource BgHoverBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Mode}" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>
                                            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="12,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding AnimationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Foreground="{DynamicResource AccentBlueBrush}"
                                                         FontSize="11" BorderThickness="0,0,0,1" Padding="2,1"/>
                                                <Button Grid.Column="1" Content="📂" FontSize="11"
                                                        Padding="4,1" Margin="3,0,0,0"
                                                        Tag="{Binding}" Click="BrowseAnimation_Click"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ─── Events ────────────────────────────────────────── -->
                    <TabItem Header="Events">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- toolbar -->
                                <RowDefinition Height="Auto"/>
                                <!-- search -->
                                <RowDefinition Height="*"/>
                                <!-- list -->
                                <RowDefinition Height="4"/>
                                <!-- splitter -->
                                <RowDefinition Height="180"/>
                                <!-- usages -->
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,2">
                                <Button x:Name="BtnAddEvent" Content="+ Add" Width="64" Height="26"
                    Click="BtnAddEvent_Click" Margin="0,0,4,0"/>
                                <Button x:Name="BtnDeleteEvent" Content="🗑 Delete" Width="72" Height="26"
                    Click="BtnDeleteEvent_Click" IsEnabled="False"/>
                            </StackPanel>

                            <!-- Search -->
                            <TextBox Grid.Row="1" Margin="4,2,4,4" Padding="3"
                 x:Name="EventSearchBox"
                 Text="{Binding EventFilter, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Filter events…"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="5,3"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Events list -->
                            <ListBox Grid.Row="2" x:Name="EventsListBox"
                 ItemsSource="{Binding EventsView}"
                 SelectionChanged="EventsListBox_SelectionChanged"
                 Margin="4,0,4,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <!-- index -->
                                                <ColumnDefinition Width="*"/>
                                                <!-- name -->
                                                <ColumnDefinition Width="26"/>
                                                <!-- delete button -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Index badge -->
                                            <Border Grid.Column="0" CornerRadius="3" Padding="4,1"
                                Margin="0,0,6,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Id}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Editable name -->
                                            <TextBox Grid.Column="1"
                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 Padding="4,2" FontSize="11"
                                 Background="{DynamicResource BgInputBrush}"
                                 BorderThickness="0,0,0,1"
                                 VerticalAlignment="Center"
                                 LostFocus="EventName_LostFocus"
                                 Tag="{Binding}"/>

                                            <!-- Inline delete -->
                                            <Button Grid.Column="2" Content="✕"
                                FontSize="10" Padding="3,1"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#FF6B6B"
                                Tag="{Binding}"
                                Click="BtnDeleteEventInline_Click"
                                VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Splitter -->
                            <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" Margin="4,0"/>

                            <!-- Usages panel — unchanged -->
                            <Border Grid.Row="4" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Margin="4,0,4,4">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Margin="0,5,0,3" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Select an event to see usages"
                           Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    <TextBlock DockPanel.Dock="Top" Margin="0,5,0,3" FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVisibilityConverter}}">
                    <Run Text="Usages of: "/>
                    <Run Text="{Binding SelectedEvent.Name}" FontWeight="Bold"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
                                    </TextBlock>
                                    <ListBox ItemsSource="{Binding EventUsageList}" FontSize="11"
                         SelectionChanged="EventUsagesList_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border CornerRadius="3" Padding="4,1"
        Margin="0,0,6,0" VerticalAlignment="Center">
    <Border.Style>
        <Style TargetType="Border">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsageType}" Value="Transition">
                    <Setter Property="Background" Value="#1A3A5C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageType}" Value="Wildcard">
                    <Setter Property="Background" Value="#3A1A5C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageType}" Value="Trigger">
                    <Setter Property="Background" Value="#1A3A1A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageType}" Value="Property">
                    <Setter Property="Background" Value="#3A2A00"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Border.Style>
    <TextBlock Text="{Binding UsageType}" FontSize="10" FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}"/>
</Border>
                                                        <TextBlock Text="{Binding Description}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Row="1" Text="{Binding ClassName}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10" Margin="0,1,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ─── Transitions ───────────────────────────────────── -->
                    <TabItem Header="Transitions">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Margin="4,4,4,4" Padding="3"
                                     Text="{Binding TransitionFilter, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Filter by state or event…"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           Margin="5,3"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <ListBox Grid.Row="1" ItemsSource="{Binding TransitionsView}"
                                     SelectionChanged="TransitionsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding FromState}" FontWeight="SemiBold"/>
                                                <TextBlock Text=" ➔ " Foreground="{DynamicResource BadgePurpleTextBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding ToState}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                                                <Border CornerRadius="3" Padding="4,1" Margin="0,0,4,0"
                                                        Background="{DynamicResource BadgePurpleBrush}">
                                                    <TextBlock Text="{Binding EventName}" FontSize="10"
                                                               Foreground="{DynamicResource BadgePurpleTextBrush}"/>
                                                </Border>
                                                <Border CornerRadius="3" Padding="4,1"
                                                        Background="{DynamicResource BadgeBlueBrush}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="blend: " FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding BlendDuration}" FontSize="10"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                                          Background="{DynamicResource BorderBrush}" Margin="4,0"/>
                            <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0" Margin="4,0,4,4">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Margin="0,5,0,3" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Select a transition to see details"
                                               Visibility="{Binding SelectedTransition, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    <TextBlock DockPanel.Dock="Top" Margin="0,5,0,3" FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Visibility="{Binding SelectedTransition, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Run Text="Details: "/>
                                        <Run Text="{Binding SelectedTransition.FromState}" FontWeight="Bold"
                                             Foreground="{DynamicResource AccentBlueBrush}"/>
                                        <Run Text=" ➔ "/>
                                        <Run Text="{Binding SelectedTransition.ToState}" FontWeight="Bold"
                                             Foreground="{DynamicResource AccentBlueBrush}"/>
                                    </TextBlock>
                                    <ListBox ItemsSource="{Binding TransitionDetailList}" FontSize="11"
                                             SelectionChanged="TransitionDetail_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.ColumnSpan="2" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,4,0,2">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Label}" Value="──">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Text" Value="{Binding Value}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Label}" Value="──">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="11" TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Label}" Value="──">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ─── SM Inspector ──────────────────────────────────── -->
                    <TabItem Header="SM Inspector">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ComboBox Grid.Row="0" Margin="4"
                                      ItemsSource="{Binding SmList}"
                                      SelectedItem="{Binding SelectedSM, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Id, Mode=OneWay}"/>
                                            <Run Text="  "/>
                                            <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,2">
                                <Button Content="+ Add Transition" Width="120" Height="28" Margin="0,0,6,0"
                                        Click="BtnAddSmTransition_Click"/>
                                <Button x:Name="BtnEditSmTransition" Content="✏ Edit" Width="72" Height="28"
                                        Margin="0,0,6,0" IsEnabled="False" Click="BtnEditSmTransition_Click"/>
                                <Button x:Name="BtnDeleteSmTransition" Content="🗑 Delete" Width="80" Height="28"
                                        IsEnabled="False" Click="BtnDeleteSmTransition_Click"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" x:Name="SmTransitionsGrid"
                                      ItemsSource="{Binding SmTransitionRows}"
                                      SelectedItem="{Binding SelectedSmRow, Mode=TwoWay}"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      CanUserDeleteRows="False" IsReadOnly="True"
                                      SelectionChanged="SmTransitionsGrid_SelectionChanged"
                                      Margin="4,0,4,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="From"  Binding="{Binding FromState}"     Width="*"/>
                                    <DataGridTextColumn Header="To"    Binding="{Binding ToState}"       Width="*"/>
                                    <DataGridTextColumn Header="Event" Binding="{Binding EventName}"     Width="*"/>
                                    <DataGridTextColumn Header="Blend" Binding="{Binding BlendDuration}" Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ─── Bindings ──────────────────────────────────────── -->
                    <TabItem Header="Bindings">
                        <DockPanel Margin="0,5,0,0">
                            <TextBox DockPanel.Dock="Top" Margin="5,0,5,5" Padding="3"
                                     Text="{Binding BindingFilter, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Filter bindings…"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           Margin="5,3"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <ListBox ItemsSource="{Binding BindingsView}"
                                     SelectionChanged="BindingsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding OwnerName}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                <Border CornerRadius="3" Padding="4,1"
                                                        Background="{DynamicResource BadgeGrayBrush}">
                                                    <TextBlock Text="{Binding OwnerClass}" FontSize="10"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                                                <Border CornerRadius="3" Padding="4,1" Margin="0,0,5,0"
                                                        Background="{DynamicResource BadgeGreenBrush}">
                                                    <TextBlock Text="{Binding VariableName}" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BadgeGreenTextBrush}"/>
                                                </Border>
                                                <TextBlock Text="→" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding MemberPath}"
                                                           Foreground="{DynamicResource AccentBlueBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ─── Project ───────────────────────────────────────────────── -->
                    <TabItem Header="📦 Project">
                        <DockPanel Margin="0,6,0,0">

                            <!-- Header info -->
                            <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,6" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Project File" FontWeight="Bold" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="ProjectFilePath"
                           Text="No project loaded"
                           FontSize="10"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Toolbar -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5,0,0,8">
                                <Button Content="📂 Open Project" Click="BtnOpenProject_Click"
                    Padding="8,4" Margin="0,0,6,0"/>
                                <Button Content="💾 Save Project" Click="BtnSaveProject_Click"
                    Padding="8,4" Margin="0,0,6,0"/>
                                <Button Content="🆕 New Project" Click="BtnNewProject_Click"
                    Padding="8,4"/>
                            </StackPanel>

                            <!-- World settings -->
                            <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgMidBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,6" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="World Up" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBox Grid.Column="1" x:Name="TxtWorldUpWS"
                         FontSize="11" Padding="3,2" Margin="0,0,0,4"
                         Text="(0.000000 0.000000 1.000000 0.000000)"/>

                                    <TextBlock Grid.Row="1" Text="Default Event Mode" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtDefaultEventMode"
                         FontSize="11" Padding="3,2"
                         Text="EVENT_MODE_IGNORE_FROM_GENERATOR"/>
                                </Grid>
                            </Border>

                            <!-- Characters list header -->
                            <DockPanel DockPanel.Dock="Top" Margin="5,0,5,4" LastChildFill="False">
                                <TextBlock Text="Characters" FontWeight="SemiBold" FontSize="11"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="+ Add" Padding="6,2"
                    Click="BtnAddCharacterRef_Click"/>
                            </DockPanel>

                            <!-- Characters list -->
                            <ListBox x:Name="ProjectCharactersList"
                 ItemsSource="{Binding Workspace.Project.Characters}"
                 SelectionChanged="ProjectCharactersList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status dot -->
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BehaviorFile}" Value="{x:Null}">
                                                                <Setter Property="Fill" Value="#CC7700"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding File.OriginalPath}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Open ↗" Padding="5,2"
                                Margin="6,0,0,0" FontSize="10"
                                Tag="{Binding}"
                                Click="BtnOpenCharacterFromProject_Click"/>
                                            <Button Grid.Column="3" Content="✕" Padding="5,2"
                                Margin="4,0,0,0" FontSize="10"
                                Foreground="#FF6B6B"
                                Background="Transparent" BorderThickness="0"
                                Tag="{Binding}"
                                Click="BtnRemoveCharacterRef_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        </DockPanel>
                    </TabItem>

                    <!-- ─── Character ─────────────────────────────────────────────── -->
                    <TabItem Header="🧑 Character">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,6,8,12">

                                <!-- Header -->
                                <Border Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1" Padding="8,6" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Character File" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="CharacterFilePath"
                               Text="No character loaded"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Toolbar -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="📂 Open Character" Click="BtnOpenCharacter_Click"
                        Padding="8,4" Margin="0,0,6,0"/>
                                    <Button Content="💾 Save Character" Click="BtnSaveCharacter_Click"
                        Padding="8,4"/>
                                </StackPanel>

                                <!-- Section: Identity -->
                                <TextBlock Text="IDENTITY" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource BgMidBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Character Name" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="TxtCharacterName"
                             FontSize="11" Padding="3,2"
                             TextChanged="CharacterField_Changed"/>
                                    </Grid>
                                </Border>

                                <!-- Section: Physics -->
                                <TextBlock Text="PHYSICS CAPSULE" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource BgMidBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Capsule Height" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="TxtCapsuleHeight"
                             FontSize="11" Padding="3,2" Margin="0,0,8,0"
                             TextChanged="CharacterField_Changed"/>
                                        <TextBlock Grid.Column="2" Text="Capsule Radius" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <TextBox Grid.Column="3" x:Name="TxtCapsuleRadius"
                             FontSize="11" Padding="3,2"
                             TextChanged="CharacterField_Changed"/>
                                    </Grid>
                                </Border>

                                <!-- Section: Paths -->
                                <TextBlock Text="FILE PATHS" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource BgMidBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Skeleton -->
                                        <TextBlock Text="Skeleton" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="TxtSkeletonPath"
                             FontSize="11" Padding="3,2"
                             TextChanged="CharacterField_Changed"/>
                                        <Button Grid.Column="2" Content="📂" Padding="5,2" Margin="4,0,0,0"
                            Click="BtnBrowseSkeleton_Click"/>

                                        <!-- Ragdoll -->
                                        <TextBlock Grid.Row="2" Text="Ragdoll" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtRagdollPath"
                             FontSize="11" Padding="3,2"
                             TextChanged="CharacterField_Changed"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="📂" Padding="5,2"
                            Margin="4,0,0,0" Click="BtnBrowseRagdoll_Click"/>

                                        <!-- Behavior -->
                                        <TextBlock Grid.Row="4" Text="Behavior" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtBehaviorPath"
                             FontSize="11" Padding="3,2"
                             TextChanged="CharacterField_Changed"/>
                                        <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="📂" Padding="5,2" Margin="4,0,0,0"
                                Click="BtnBrowseBehavior_Click"/>
                                            <Button Content="Open ↗" Padding="5,2" Margin="4,0,0,0"
                                FontSize="10"
                                Click="BtnOpenLinkedBehavior_Click"
                                ToolTip="Open this behavior file"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Section: Animations -->
                                <DockPanel Margin="0,0,0,4" LastChildFill="False">
                                    <TextBlock Text="ANIMATION NAMES" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" Content="+ Add"
                        Padding="6,2" Click="BtnAddAnimationName_Click"/>
                                </DockPanel>
                                <Border Background="{DynamicResource BgMidBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,0,12">
                                    <ListBox x:Name="AnimationNamesList"
                         ItemsSource="{Binding Workspace.Character.AnimationNames}"
                         MaxHeight="200">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding ., Mode=TwoWay,
                                               UpdateSourceTrigger=LostFocus}"
                                         FontSize="11" Padding="3,2"
                                         Foreground="{DynamicResource AccentBlueBrush}"
                                         BorderThickness="0,0,0,1"/>
                                                    <Button Grid.Column="1" Content="📂"
                                        Padding="4,2" Margin="4,0,0,0"
                                        FontSize="10"
                                        Tag="{Binding}"
                                        Click="BtnBrowseAnimName_Click"/>
                                                    <Button Grid.Column="2" Content="✕"
                                        Padding="4,2" Margin="2,0,0,0"
                                        FontSize="10" Foreground="#FF6B6B"
                                        Background="Transparent" BorderThickness="0"
                                        Tag="{Binding}"
                                        Click="BtnRemoveAnimName_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <!-- ─── Live Debugger ──────────────────────────────────────── -->
                    <TabItem x:Name="DebuggerTab" Header="🎮 Debugger">
                        <DockPanel Background="#0F0F1A">
                            <Border DockPanel.Dock="Top"
                Background="#1A1A2E"
                BorderBrush="#3F3F55" BorderThickness="0,0,0,1"
                Padding="8,5">
                                <DockPanel>
                                    <Button x:Name="BtnDetachDebugger"
                        Content="⧉ Pop Out"
                        DockPanel.Dock="Right"
                        Click="BtnDetachDebugger_Click"
                        Padding="6,3" FontSize="11"/>
                                    <TextBlock Text="Live Debugger"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#9D9D9D"
                           VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <!-- Binds to GraphView's shared VM -->
                            <dialogs:DebugPanelView x:Name="DebugTabPanel"/>
                        </DockPanel>
                    </TabItem>
                    <!-- ─── Bookmarks ─────────────────────────────────────── -->
                    <TabItem Header="🔖 Bookmarks">
                        <DockPanel Margin="0,5,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="Bookmarks" FontWeight="Bold" Margin="5,0,0,8"/>
                            <ListBox x:Name="BookmarksList" ItemsSource="{Binding Bookmarks}"
                                     SelectionChanged="BookmarksList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔖 " Foreground="Goldenrod"/>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ClassName}" FontSize="10"
                                                           Foreground="{DynamicResource AccentBlueBrush}" Margin="16,1,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="✕" Padding="6,2"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#FF6B6B" Tag="{Binding}"
                                                    Click="BtnRemoveBookmark_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                </TabControl>

                <GridSplitter Grid.Column="3"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"
                              ResizeDirection="Columns" Cursor="SizeWE"/>

                <!-- ── COL 4: Object Data — always visible ───────────────── -->
                <Border Grid.Column="4"
                        Background="{DynamicResource BgMidBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,0,0,0">
                    <DockPanel>

                        <!-- Header bar -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource BgPanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="6,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnBackNavigation"
                                        Content="← Back" IsEnabled="False"
                                        Click="BtnBackNavigation_Click"
                                        Padding="5,2" FontSize="11"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="SelectedClassName"
                                           Text="Object Data"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Margin="6,0" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2"
                                        x:Name="BtnBookmarkToggle"
                                        Content="🔖" Padding="4,2" FontSize="13"
                                        ToolTip="Bookmark this object"
                                        Click="BtnBookmarkToggle_Click"
                                        Background="Transparent" BorderThickness="0"/>
                            </Grid>
                        </Border>

                        <!-- Object name / class -->
                        <TextBlock DockPanel.Dock="Top"
                                   x:Name="ObjectNameLabel"
                                   Padding="7,4" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Background="{DynamicResource BgDarkBrush}"/>

                        <!-- Params list -->
                        <ListBox x:Name="ParamsEditor"
                                 HorizontalContentAlignment="Stretch"
                                 TextElement.Foreground="{DynamicResource InputTextBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="11"
                                                   VerticalAlignment="Top" Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="3" FontSize="11"
                                                     PreviewMouseLeftButtonDown="ParamValue_PreviewMouseLeftButtonDown"
                                                     PreviewMouseMove="ParamValue_PreviewMouseMove">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="null">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding Value, Converter={StaticResource ReferenceCheckConverter}}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <Button Content="✏ Edit States" Margin="0,2,0,0"
                                                    HorizontalAlignment="Left" Padding="5,2"
                                                    Tag="{Binding}" Click="BtnEditStates_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Name}" Value="states">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <!-- Inline children -->
                                            <ItemsControl ItemsSource="{Binding Children}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,2,0,0" Padding="4,2"
                                                                Background="{DynamicResource BgDarkBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1,0,0,0">
                                                            <ItemsControl ItemsSource="{Binding Params}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,1">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="100"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       FontSize="10" VerticalAlignment="Center"/>
                                                                            <TextBox Grid.Column="1"
                                                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     FontSize="10" Padding="2,1">
                                                                                <TextBox.Style>
                                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                        <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                                                                        <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 STATUS BAR
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📄 " FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.FileName}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Stats.Summary}"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="StatusText" FontSize="11"
                                   Foreground="{DynamicResource AccentGreenBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
